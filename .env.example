# ── Option A: Claude API (paid, best quality) ─────────────────────────────────
ANTHROPIC_API_KEY=your_api_key_here

# ── Option B: Local model via Ollama (free, no internet required) ─────────────
# 1. Install Ollama: https://ollama.com
# 2. Pull a model:  ollama pull qwen2.5:7b
# 3. Uncomment the two lines below:
# BACKEND=ollama
# OLLAMA_MODEL=qwen2.5:7b

# Other Ollama options:
#   OLLAMA_MODEL=llama3.1:8b       (good general purpose, needs ~5 GB)
#   OLLAMA_MODEL=qwen2.5:14b       (better quality, needs ~9 GB)
#   OLLAMA_MODEL=mistral:7b        (fast, decent at JSON)
# OLLAMA_BASE_URL=http://localhost:11434/v1   (default, change if Ollama runs elsewhere)
