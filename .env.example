# ── Anthropic ──────────────────────────────────────────────────────────────
# Sign up at https://console.anthropic.com, then create a key under API Keys.
ANTHROPIC_API_KEY=sk-ant-...

# ── Trello ─────────────────────────────────────────────────────────────────
# 1. Go to https://trello.com/power-ups/admin and create a new Power-Up to get
#    your API key.
# 2. Get your token by visiting (replace YOUR_KEY):
#    https://trello.com/1/authorize?expiration=never&scope=read&response_type=token&key=YOUR_KEY
# 3. Find your board ID: open the board in Trello, append .json to the URL,
#    and look for "id" at the top level — or use the short URL slug.
TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_BOARD_ID=
